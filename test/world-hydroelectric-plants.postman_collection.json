    {
      "name": "Busqueda periodo de tiempo (200 OK)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Response is an array\", function () {\r",
              "    pm.expect(pm.response.json()).to.be.an('array');\r",
              "});\r",
              "\r",
              "pm.test(\"All items are within the specified year range\", () => {\r",
              "    const data = pm.response.json();\r",
              "    const fromYear = Number(pm.request.url.query.get(\"from\"));\r",
              "    const toYear = Number(pm.request.url.query.get(\"to\"));\r",
              "    \r",
              "    data.forEach(item => {\r",
              "        pm.expect(item.year).to.be.at.least(fromYear);\r",
              "        pm.expect(item.year).to.be.at.most(toYear);\r",
              "    });\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
