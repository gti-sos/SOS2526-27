              "\r",
              "pm.test(\"Response is an object\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData).to.be.an('object');\r",
              "    pm.expect(jsonData).to.not.be.an('array');\r",
              "});\r",
              "\r",
              "pm.test(\"Content matches the requested resource\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "\r",
              "    const pathSegments = pm.request.url.path;\r",
              "    const expectedName = decodeURIComponent(pathSegments[pathSegments.length - 2]);\r",
              "    const expectedYear = Number(pathSegments[pathSegments.length - 1]);\r",
              "\r",
              "    pm.expect(jsonData.name).to.eql(expectedName);\r",
              "    pm.expect(jsonData.year).to.eql(expectedYear);\r",
              "});"
            ],
